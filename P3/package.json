{
  "name": "semaforo-inteligente-3d",
  "version": "0.1.0",
  "private": true,
  "description": "Simulación 3D de un semáforo inteligente en una intersección — Paradigmas de la Programación",
  "workspaces": [
    "shared",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
